# Server
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/smautomation

# Auth
JWT_SECRET=your-jwt-secret-here

# Meta webhooks (Facebook, Instagram, WhatsApp)
# Verify token: duhet të përputhet me atë që vendos në Meta Developer Console (Webhooks → Verify Token)
META_WEBHOOK_VERIFY_TOKEN=your-verify-token
# App Secret (opsional): për validim të nënshkrimit X-Hub-Signature-256 në POST webhook
META_APP_SECRET=

# AI – Groq (Llama) – përdoret nga pipeline kur nuk ka automation/keyword match
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_URL=https://api.groq.com/openai/v1
